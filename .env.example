# Copy to .env on the NAS and fill in (values live in the old launchd plists).
# docker compose reads this automatically.

# cookie signing secret — keep it FIXED so logins survive restarts
AUTH_SECRET=
# local-only CLI token login (optional; OAuth2 is the real login path)
AUTH_TOKEN=

# Synology OIDC (browser login)
OAUTH2_CLIENT_ID=
OAUTH2_CLIENT_SECRET=
OAUTH2_AUTH_URL=https://your-idp.example.com:9000/webman/sso/SSOOauth.cgi
OAUTH2_TOKEN_URL=https://your-idp.example.com:9000/webman/sso/SSOAccessToken.cgi
OAUTH2_USERINFO_URL=https://your-idp.example.com:9000/webman/sso/SSOUserInfo.cgi
OAUTH2_REDIRECT_URI=https://your-hub.example.com:9000/auth/oauth2/callback
OAUTH2_SCOPE=openid email

# Claude usage — now built into zsh-web (the usage service owns the accounts &
# polls Anthropic itself; the standalone cc-monitor is retired).
# Outbound proxy for reaching Anthropic, e.g. http://user:pass@host:port. Optional.
CC_PROXY=
# Usage poll interval in ms (default 5 min).
POLL_INTERVAL_MS=300000
